# Anthropic API Key — required for live AI analysis
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-key-here

# The app works without this key using pre-generated mock analyses.
# Only needed if you want to trigger live re-analysis via the "Analyze" button.

# Groq API Key — last-resort fallback when Claude is unavailable
# Get yours at: https://console.groq.com/
GROQ_API_KEY=gsk_your-key-here
